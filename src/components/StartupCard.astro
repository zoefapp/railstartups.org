---
import type { CollectionEntry } from "astro:content";

interface Props {
    startup: CollectionEntry<"startups">["data"];
    id: string;
}

const { startup, id } = Astro.props;
---

<div
    class="startup-card transition-all duration-500 ease-in-out opacity-0 translate-y-8"
    data-id={id}
    data-name={startup.companyName.toLowerCase()}
    data-categories={startup.categories.join(',')}
>
    <div
        class="h-full bg-white rounded-lg border border-slate-200/80 shadow-sm p-4 hover:border-teal-500 hover:shadow-md transition-all cursor-pointer"
        hx-get={`/startups/${id}/`}
        hx-target="#startup-dialog-content"
        hx-select=".startup-detail"
    >
        <div class="flex gap-3">
            <div class="w-16 h-16 flex-shrink-0">
                {startup.logo && (
                    <img
                        src={startup.logo.src}
                        alt={startup.companyName}
                        class="w-16 h-16 object-contain rounded"
                    />
                )}
            </div>
            <div class="min-w-0">
                <h2 class="text-lg font-bold text-slate-900 truncate">{startup.companyName}</h2>
                <p class="text-xs text-slate-500"><span class="inline-block mr-0.5">📍</span>{startup.country}</p>
                <p class="text-sm text-slate-600 mt-1 line-clamp-2">{startup.shortDescription}</p>
            </div>
        </div>
        <div class="flex flex-wrap gap-1 mt-3">
            {startup.categories.map((cat: string) => (
                <span class="bg-teal-50 text-teal-600 text-[10px] font-medium px-1.5 py-0.5 rounded-full uppercase tracking-wide">
                    {cat}
                </span>
            ))}
        </div>
    </div>
</div>

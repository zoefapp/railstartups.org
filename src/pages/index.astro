---
import Layout from "../layouts/Layout.astro";
import StartupsContainer from "../components/StartupsContainer.astro";
import { getCollection } from "astro:content";
import GithubRibbon from "../components/GithubRibbon.astro";

const startupsCollection = await getCollection("startups");
const startups = startupsCollection.map((startup) => ({ ...startup.data, id: startup.id }));
const startupFilters = startups
  .map((startup) => startup.categories)
  .flat()
  .filter((v, i, a) => a.indexOf(v) === i);

---

<Layout title="Railstartups.org" description="A curated list of startups in the railway industry!">
  <main
    id="main-content"
    class="grid bg-slate-100/90 border border-slate-300 backdrop-blur-sm min-h-screen rounded-lg p-4 md:p-8"
  >
    <StartupsContainer
      startups={startups}
      startupFilters={startupFilters}
    />
  </main>

  <dialog
    id="startup-dialog"
    aria-modal="true"
    aria-label="Startup details"
    class="w-full max-w-3xl rounded-lg p-0 backdrop:bg-black/50 backdrop:backdrop-blur-sm"
  >
    <div class="relative">
      <button
        id="startup-dialog-close"
        class="absolute top-4 right-4 z-10 text-slate-500 hover:text-slate-700 text-2xl leading-none cursor-pointer focus:outline-none focus:ring-2 focus:ring-teal-600 focus:ring-offset-2 rounded"
        aria-label="Close dialog"
      >&times;</button>
      <div id="startup-dialog-content"></div>
      <div class="flex justify-between items-center border-t border-slate-100 mx-6 md:mx-8 py-4">
        <button
          id="startup-dialog-prev"
          class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-teal-700 bg-slate-100 hover:bg-slate-200 rounded-lg transition-colors disabled:text-slate-400 disabled:cursor-default disabled:hover:bg-slate-100 cursor-pointer focus:outline-none focus:ring-2 focus:ring-teal-600 focus:ring-offset-2"
        >&larr; Previous</button>
        <button
          id="startup-dialog-next"
          class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-teal-700 bg-slate-100 hover:bg-slate-200 rounded-lg transition-colors disabled:text-slate-400 disabled:cursor-default disabled:hover:bg-slate-100 cursor-pointer focus:outline-none focus:ring-2 focus:ring-teal-600 focus:ring-offset-2"
        >Next &rarr;</button>
      </div>
    </div>
  </dialog>

  <script is:inline>
    var dialog = document.getElementById('startup-dialog');
    var closeBtn = document.getElementById('startup-dialog-close');
    var prevBtn = document.getElementById('startup-dialog-prev');
    var nextBtn = document.getElementById('startup-dialog-next');
    var currentStartupId = null;

    function getVisibleIds() {
      return Array.from(document.querySelectorAll('.startup-card'))
        .filter(function(card) { return card.style.display !== 'none'; })
        .map(function(card) { return card.getAttribute('data-id'); })
        .filter(Boolean);
    }

    function updateNavButtons() {
      var ids = getVisibleIds();
      var idx = currentStartupId ? ids.indexOf(currentStartupId) : -1;
      prevBtn.disabled = idx <= 0;
      nextBtn.disabled = idx < 0 || idx >= ids.length - 1;
    }

    function navigateTo(id) {
      currentStartupId = id;
      var target = document.getElementById('startup-dialog-content');
      htmx.ajax('GET', '/startups/' + id + '/', { target: target, select: '.startup-detail' });
    }

    document.body.addEventListener('htmx:beforeRequest', function(e) {
      var el = e.detail.elt;
      var card = el.closest && el.closest('.startup-card');
      if (card) {
        currentStartupId = card.getAttribute('data-id');
      }
    });

    document.body.addEventListener('htmx:afterSwap', function(e) {
      if (e.detail.target && e.detail.target.id === 'startup-dialog-content') {
        updateNavButtons();
        if (!dialog.open) {
          dialog.showModal();
          closeBtn.focus();
        }
      }
    });

    prevBtn.addEventListener('click', function() {
      var ids = getVisibleIds();
      var idx = currentStartupId ? ids.indexOf(currentStartupId) : -1;
      if (idx > 0) navigateTo(ids[idx - 1]);
    });

    nextBtn.addEventListener('click', function() {
      var ids = getVisibleIds();
      var idx = currentStartupId ? ids.indexOf(currentStartupId) : -1;
      if (idx >= 0 && idx < ids.length - 1) navigateTo(ids[idx + 1]);
    });

    document.addEventListener('keydown', function(e) {
      if (!dialog.open) return;
      if (e.key === 'ArrowLeft' && !prevBtn.disabled) {
        e.preventDefault();
        prevBtn.click();
      } else if (e.key === 'ArrowRight' && !nextBtn.disabled) {
        e.preventDefault();
        nextBtn.click();
      }
    });

    closeBtn.addEventListener('click', function() { dialog.close(); });
    dialog.addEventListener('click', function(e) {
      if (e.target === dialog) dialog.close();
    });
  </script>

  <GithubRibbon />
</Layout>
